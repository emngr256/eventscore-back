generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ORGANIZER
  JURY
  PARTICIPANT
}

enum SubmissionStatus {
  PENDING
  SCORED
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String       @map("password_hash")
  name         String
  role         Role
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  createdEvents Event[]     @relation("EventCreator")
  submissions  Submission[]
  scores       Score[]
  juryEvents   EventJury[]

  @@map("users")
}

model Event {
  id          String       @id @default(uuid())
  title       String
  description String?
  rules       String?
  deadline    DateTime
  isPublished Boolean      @default(true) @map("is_published")
  anonymous   Boolean      @default(false)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  createdById String       @map("created_by_id")
  createdBy   User         @relation("EventCreator", fields: [createdById], references: [id])

  submissions Submission[]
  criteria    Criteria[]
  juryMembers EventJury[]

  @@map("events")
}

model EventJury {
  id       String @id @default(uuid())
  eventId  String @map("event_id")
  juryId   String @map("jury_id")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  jury  User  @relation(fields: [juryId], references: [id], onDelete: Cascade)

  @@unique([eventId, juryId])
  @@map("event_juries")
}

model Submission {
  id             String           @id @default(uuid())
  teamName       String           @map("team_name")
  workUrl        String           @map("work_url")
  certificateId  String?          @unique @map("certificate_id")
  status         SubmissionStatus @default(PENDING)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  eventId   String   @map("event_id")
  event     Event    @relation(fields: [eventId], references: [id])

  captainId String   @map("captain_id")
  captain   User     @relation(fields: [captainId], references: [id])

  scores    Score[]

  @@map("submissions")
}

model Criteria {
  id          String @id @default(uuid())
  name        String
  description String?
  maxScore    Int    @map("max_score")

  eventId     String @map("event_id")
  event       Event  @relation(fields: [eventId], references: [id])

  scores      Score[]

  @@map("criteria")
}

model Score {
  id          String   @id @default(uuid())
  value       Int
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  submissionId String  @map("submission_id")
  submission   Submission @relation(fields: [submissionId], references: [id])

  juryId      String   @map("jury_id")
  jury        User     @relation(fields: [juryId], references: [id])

  criteriaId  String   @map("criteria_id")
  criteria    Criteria @relation(fields: [criteriaId], references: [id])

  @@unique([submissionId, juryId, criteriaId])
  @@map("scores")
}
